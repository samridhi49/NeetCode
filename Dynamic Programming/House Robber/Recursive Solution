class Solution {
public:
    int f(vector<int>& nums, int i) {
        if(i == 0)
            return nums[0];

        if(i < 0)
            return 0;

        int pick = nums[i] + f(nums, i - 2);
        int not_pick = f(nums, i - 1);
        
        return max(pick, not_pick);
    }

    int rob(vector<int>& nums) {
        return f(nums, nums.size() - 1);
    }
};